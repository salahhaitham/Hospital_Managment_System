<?xml version="1.0" encoding="utf-8"?>
<odoo>


    <record id="view_hospital_patient_form" model="ir.ui.view">
        <field name="name">hospital.patient.form</field>
        <field name="model">hospital.patient</field>
        <field name="arch" type="xml">
            <form string="Patient">


                <sheet>


                    <header>

                         <button name="draft_button" string="Draft" type="object" class="btn_primary" invisible="state in ('draft','closed')"/>
                         <button name="confirm_button" string="Confirmed" type="object" class="btn_secondary" invisible="state != 'draft'"/>
                         <button name="done_button" string="Done" type="object" class="btn_success" invisible="state != 'confirm'"/>
                        <button name="cancel_button" string="Cancel" type="object" class="btn_success" invisible="state == 'cancel  '"/>
                         <field name="state" widget="statusbar"/>

                    </header>
                     <field name="priority" widget="priority"/>
                    <field name="image"
                           widget="image"
                           class="oe_avatar"
                           options="{'preview_image': 'image'}"/>


                    <div class="oe_title">

                        <h1>
                            <field name="name"
                                   placeholder="Patient Name..."
                                   required="1"/>
                              <field name="ref"

                               />
                        </h1>
                    </div>
                    <group>
                        <group string="Personal Info">
                            <field name="age"/>
                            <field name="gender"/>
                            <field name="date_of_birth"/>
                            <field name="is_discharged"/>
                             <field name="doctor_id" widget="many2one_avatar_user"/>
                        </group>
                        <group string="Appointment Info">
                            <field name="responsible_id"/>
                            <field name="appointment_date"/>
                            <field name="tag_ids" widget="many2many_tags"/>

                        </group>
                    </group>
                    <notebook>
                        <page string="Notes">
                            <field name="note" placeholder="Write notes here..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>


    <record id="view_hospital_patient_tree" model="ir.ui.view">
        <field name="name">hospital.patient.tree</field>
        <field name="model">hospital.patient</field>
        <field name="arch" type="xml">
            <list string="Patients" multi_edit="1"
                  decoration-success="state == 'done'"
                  decoration-info="state  in ('draft','confirm')"
                  decoration-danger="state == 'cancel'"
               >
                <field name="name"/>
                <field name="age"/>
                <field name="gender"/>
                <field name="date_of_birth"/>
               <field name="doctor_id" widget="many2one_avatar"/>
                <field name="responsible_id"/>
                <field name="appointment_date"/>
                <field name="state" widget="badge" decoration-success="state == 'done'"
                       decoration-info="state  in ('draft','confirm')"
                        decoration-danger="state == 'cancel'"

                />

                <field name="active" invisible="1"/>
            </list>
        </field>
    </record>

   <record id="view_hospital_patient_search" model="ir.ui.view">
    <field name="name">hospital.patient.search</field>
    <field name="model">hospital.patient</field>
    <field name="arch" type="xml">
        <search>
            <field name="name"/>

            <filter name="male_gender" string="Male" domain="[('gender','=','male')]"/>
            <filter name="female_gender" string="Female" domain="[('gender','=','female')]"/>
            <filter name="female_gender" string="gender" context="{'group_by':'gender'}"/>
         <searchpanel>
             <field name="gender" string="Gender" enable_counter="1" select="multi" icon="fa-users"/>
         </searchpanel>
        </search>
    </field>
</record>



    <record id="action_hospital_patient" model="ir.actions.act_window">
        <field name="name">Patients</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">hospital.patient</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
        <field name="help" type="xml">
            <p class="o_view_nocontent_smiling_face">
                No patients found! Create your first patient.
            </p>
        </field>
    </record>


    <record id="action_hospital_patient_Female" model="ir.actions.act_window">
        <field name="name">Draft Patients</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">hospital.patient</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('gender', '=', 'female')]</field>
        <field name="context">{'default_gender': 'female'}</field>
    </record>






</odoo>
