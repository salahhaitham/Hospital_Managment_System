<odoo>
  <data>

       <record id="view_hospital_appointment_tree" model="ir.ui.view">
      <field name="name">hospital.appointment.tree</field>
      <field name="model">hospital.appointment</field>
      <field name="arch" type="xml">

        <list string="Appointments">
          <field name="name"/>
          <field name="patient_id"/>
          <field name="appointment_date"/>
          <field name="state" widget="badge"/>
        </list>

      </field>
    </record>
    <!-- FORM VIEW -->
    <record id="view_hospital_appointment_form" model="ir.ui.view">
      <field name="name">hospital.appointment.form</field>
      <field name="model">hospital.appointment</field>
      <field name="arch" type="xml">

        <form string="Appointment">

          <header>
            <button name="action_confirm"
                    type="object"
                    string="Confirm"
                    class="btn-primary"
                             invisible="state != 'draft'"/>

            <button name="action_done"
                    type="object"
                    string="Done"
                    class="btn-success"
                   invisible="state != 'confirmed'"/>
              <button name="action_cancel"
                    type="object"
                    string="Cancel"
                    class="btn-danger"

            />

<!--            <button name="%(hospital.cancel_appointment_wizard_action)d"-->
<!--                    type="action"-->
<!--                    string="Cancel"-->
<!--                    class="btn-danger"-->
<!--            context="{'default_appointment_id': id}"-->
<!--            />-->

            <field name="state" widget="statusbar"/>
          </header>

          <sheet>
            <group>
              <field name="name"/>
              <field name="patient_id"/>
              <field name="appointment_date"/>
              <field name="doctor_id"/>
            
              <field name="is_paid" widget="boolean_toggle"/>
            </group>

            <group>
              <field name="notes"/>
            </group>
               <notebook>
            <page string="pharmacy">
              <field name="appointment_phamacy_line_ids" >
                <list editable="bottom">

                  <field name="product_id"/>
                <field name="qty"/>
                <field name="price" column_invisible="parent.doctor_id == False "/>
                </list>

              </field>

            </page>
          </notebook>
          </sheet>


        </form>

      </field>
    </record>

    

    <!-- ACTION -->
    <record id="action_hospital_appointment" model="ir.actions.act_window">
      <field name="name">Appointments</field>
      <field name="res_model">hospital.appointment</field>
      <field name="view_mode">list,form</field>
    </record>

    <!-- MENU -->


  </data>
</odoo>