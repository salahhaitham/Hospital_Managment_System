<odoo>

<record id="cancel_appintment_wizard_form" model="ir.ui.view">
    <field name="name">cancel.appointment.wizard form</field>
    <field name="model">cancel.appointment.wizard</field>
    <field name="arch" type="xml">
        <form >
            <sheet>

                <group>



                        <field name="reason" required="1"/>
                    <field name="appointment_id" required="1"/>

                </group>
                  <footer>
                      <button string="cancel" special="cancel"></button>
                        <button name="confirm_button" string="Confirm" type="object"></button>
                  </footer>

            </sheet>
        </form>
    </field>
</record>

    <record id="cancel_appointment_wizard_action" model="ir.actions.act_window">
        <field name="name">cancel.appointment wizard </field>
        <field name="res_model">cancel.appointment.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>

    </record>

</odoo>